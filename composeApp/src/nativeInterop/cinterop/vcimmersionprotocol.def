# Adds support for overriding the _____ functions in UIViewControllers
# This file needs to be included in the Gradle cinterop configuration:
#         iosTarget.compilations["main"].cinterops {
#             val vcimmersionprotocol by creating
#         }

package = platform.UIKitCompat
language = Objective-C
---
#import <Foundation/Foundation.h>

@protocol UIViewControllerImmersion
@required
-(BOOL)prefersHomeIndicatorAutoHidden;
-(unsigned long long)supportedInterfaceOrientations;
@end;